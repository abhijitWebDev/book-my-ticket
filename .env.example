PORT=8080

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sql_class_2_db

# JWT secret – change this to a long random string in production
JWT_SECRET=change_me_to_a_long_random_secret

# Movie currently showing (used in booking confirmation emails)
MOVIE_NAME=Dhurandhar The Revenge

# Public URL of this app – used to build links in emails
APP_URL=http://localhost:8080

# Allowed CORS origin (set to your frontend URL; for Live Server use http://127.0.0.1:5500)
CORS_ORIGIN=http://127.0.0.1:5500

# ── Autosend email service ────────────────────────────────────────────────────
AUTOSEND_API_KEY=your_autosend_api_key_here   # required – get from https://autosend.io/dashboard
EMAIL_FROM=noreply@yourdomain.com             # sender address shown to recipients

# Optional Autosend overrides (leave blank to use SDK defaults)
# AUTOSEND_BASE_URL=https://api.autosend.com/v1
# AUTOSEND_TIMEOUT=30000
# AUTOSEND_RETRIES=3
# AUTOSEND_DEBUG=false
